{
    "version": "1.0.0",
    "name": "harbor/harbor",
    "bin": [
        "bin/harbor",
        "bin/harbor-init",
        "bin/harbor-test",
        "bin/harbor-docs",
        "bin/harbor-docs-index",
        "bin/harbor-config",
        "bin/harbor-fixer",
        "bin/harbor-migration",
        "bin/harbor-seed"
    ],
    "autoload": {
        "psr-4": {
            "Harbor\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Harbor\\Tests\\": "tests/"
        }
    },
    "authors": [
        {
            "name": "Adrijan Mitrov",
            "email": "adrijan9@gmail.com"
        }
    ],
    "require": {
        "php": "^8.5",
        "ext-mysqli": "*",
        "ext-pdo": "*",
        "nesbot/carbon": "^3.8",
        "lcobucci/jwt": "^5.6"
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3.94",
        "phpunit/phpunit": "^11.5",
        "symfony/var-dumper": "^8.0",
        "rector/rector": "^2.3"
    },
    "scripts": {
        "test": "phpunit",
        "rector": "rector process --config rector.php",
        "rector:check": "rector process --config rector.php --dry-run"
    }
}
