#!/usr/bin/env php
<?php

declare(strict_types=1);

use function Harbor\Command\Flags\command_flag_no_value;
use function Harbor\Command\Flags\command_flag;
use function Harbor\Command\Flags\command_flags_init;

require __DIR__.'/../vendor/autoload.php';

require_once __DIR__.'/../src/Command/flags/command_flags.php';

if ('cli' !== PHP_SAPI) {
    return;
}

$script_file = $_SERVER['SCRIPT_FILENAME'] ?? null;
$resolved_script_file = is_string($script_file) ? realpath($script_file) : false;
if (! is_string($resolved_script_file) || __FILE__ !== $resolved_script_file) {
    return;
}

// Command usage
$command = command_flags_init('harbor-flag', $argc, $argv);
$help = command_flag_no_value($command, '-h', 'Display this help message');

if ($help) {
    \Harbor\Command\Flags\command_flags_print_usage($command);

    exit(0);
}

echo 'Command executed'.PHP_EOL;

exit(0);
