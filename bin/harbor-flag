#!/usr/bin/env php
<?php

declare(strict_types=1);

require __DIR__.'/../vendor/autoload.php';

require_once __DIR__.'/../src/Command/command_flags.php';

if ('cli' !== PHP_SAPI) {
    return;
}

$script_file = $_SERVER['SCRIPT_FILENAME'] ?? null;
$resolved_script_file = is_string($script_file) ? realpath($script_file) : false;
if (! is_string($resolved_script_file) || __FILE__ !== $resolved_script_file) {
    return;
}

// Command usage
$command = command_init('harbor-flag', $argc, $argv);
$help = command_flag($command, '-h', 'Display this help message');
$player = command_flag(
    $command,
    '-p',
    'Display this player message',
    required: static fn ($value) => ! empty($value) && strlen($value) > 7,
    defaultValue: 'Bob'
);
$someExtra = command_flag(
    $command,
    '-e',
    'Display this extra message',
    required: true,
    defaultValue: 'Extra'
);

if ($argc <= 1 || $help) {
    command_print_usage($command);

    exit(0);
}

echo 'Command executed'.PHP_EOL;
echo 'Player: '.$player.PHP_EOL;

exit(0);
