#!/usr/bin/env php
<?php

declare(strict_types=1);

require_once __DIR__.'/harbor_site.php';

function harbor_run_fixer_publisher(): void
{
    $arguments = $_SERVER['argv'] ?? [];
    $first_argument = $arguments[1] ?? null;

    if (is_string($first_argument) && in_array($first_argument, ['-h', '--help'], true)) {
        harbor_fixer_print_usage();

        return;
    }

    try {
        $published_path = harbor_publish_fixer_config();
    } catch (Throwable $throwable) {
        fwrite(STDERR, $throwable->getMessage().PHP_EOL);

        exit(1);
    }

    fwrite(STDOUT, sprintf('Published: %s%s', $published_path, PHP_EOL));
}

function harbor_publish_fixer_config(?string $working_directory = null): string
{
    $resolved_working_directory = harbor_site_resolve_working_directory($working_directory);
    harbor_site_assert_selected($resolved_working_directory);

    $source_file_path = harbor_fixer_source_file_path();
    if (! is_file($source_file_path)) {
        throw new RuntimeException(sprintf('Harbor fixer source config not found: %s', $source_file_path));
    }

    $target_file_path = $resolved_working_directory.'/.php-cs-fixer.dist.php';

    $source_content = file_get_contents($source_file_path);
    if (false === $source_content) {
        throw new RuntimeException(sprintf('Failed to read Harbor fixer source config: %s', $source_file_path));
    }

    if (false === file_put_contents($target_file_path, $source_content)) {
        throw new RuntimeException(sprintf('Failed to write fixer config file: %s', $target_file_path));
    }

    return $target_file_path;
}

function harbor_fixer_source_file_path(): string
{
    return __DIR__.'/../.php-cs-fixer.dist.php';
}

function harbor_fixer_print_usage(): void
{
    fwrite(STDOUT, 'Usage: harbor-fixer'.PHP_EOL);
    fwrite(STDOUT, PHP_EOL);
    fwrite(STDOUT, 'Publish Harbor PHP CS Fixer config into current site root.'.PHP_EOL);
    fwrite(STDOUT, 'Writes ./.php-cs-fixer.dist.php directly (overwrites existing file without prompt).'.PHP_EOL);
}

if ('cli' === PHP_SAPI) {
    $script_file = $_SERVER['SCRIPT_FILENAME'] ?? null;
    $resolved_script_file = is_string($script_file) ? realpath($script_file) : false;

    if (is_string($resolved_script_file) && __FILE__ === $resolved_script_file) {
        harbor_run_fixer_publisher();
    }
}
